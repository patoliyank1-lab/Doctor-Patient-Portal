// ─────────────────────────────────────────────────────────
// prisma/schema.prisma
// MediConnect — Full Production Database Schema
// 10 Tables | PostgreSQL | Prisma ORM
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DoctorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  APPOINTMENT
  SYSTEM
  ALERT
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ─────────────────────────────────────────────────────────
// 1. USERS
// ─────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  role           Role
  isActive       Boolean   @default(true) @map("is_active")
  emailVerified  Boolean   @default(false) @map("email_verified")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  doctor              Doctor?               @relation("UserDoctor")
  patient             Patient?              @relation("UserPatient")
  reviewedDoctors     Doctor[]              @relation("AdminDoctorReviews")
  notifications       Notification[]
  auditLogs           AuditLog[]
  verificationTokens  VerificationToken[]

  @@index([role])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────
// 2. DOCTORS
// ─────────────────────────────────────────────────────────

model Doctor {
  id                  String               @id @default(uuid())
  userId              String               @unique @map("user_id")
  firstName           String               @map("first_name") @db.VarChar(100)
  lastName            String               @map("last_name") @db.VarChar(100)
  specializations     String[]
  qualification       String?
  experienceYears     Int?                 @map("experience_years")
  bio                 String?
  profileImageUrl     String?              @map("profile_image_url")
  consultationFee     Decimal?             @map("consultation_fee") @db.Decimal(10, 2)
  approvalStatus      DoctorApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason     String?              @map("rejection_reason")
  reviewedByAdminId   String?              @map("reviewed_by_admin_id")
  reviewedAt          DateTime?            @map("reviewed_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  // Relations
  user               User               @relation("UserDoctor", fields: [userId], references: [id])
  reviewedByAdmin    User?              @relation("AdminDoctorReviews", fields: [reviewedByAdminId], references: [id])
  availabilitySlots  AvailabilitySlot[]
  appointments       Appointment[]
  medicalRecords     MedicalRecord[]
  reviews            Review[]

  @@index([approvalStatus])
  @@index([specializations])
  @@map("doctors")
}

// ─────────────────────────────────────────────────────────
// 3. PATIENTS
// ─────────────────────────────────────────────────────────

model Patient {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  firstName        String    @map("first_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  gender           Gender?
  phone            String?   @db.VarChar(20)
  address          String?
  bloodGroup       String?   @map("blood_group") @db.VarChar(5)
  profileImageUrl  String?   @map("profile_image_url")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User            @relation("UserPatient", fields: [userId], references: [id])
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  reviews         Review[]

  @@map("patients")
}

// ─────────────────────────────────────────────────────────
// 4. AVAILABILITY SLOTS
// ─────────────────────────────────────────────────────────

model AvailabilitySlot {
  id         String    @id @default(uuid())
  doctorId   String    @map("doctor_id")
  date       DateTime  @db.Date
  startTime  DateTime  @map("start_time") @db.Time
  endTime    DateTime  @map("end_time") @db.Time
  isBooked   Boolean   @default(false) @map("is_booked")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  doctor       Doctor       @relation(fields: [doctorId], references: [id])
  appointment  Appointment?

  @@unique([doctorId, date, startTime])
  @@index([doctorId, date])
  @@index([isBooked])
  @@map("availability_slots")
}

// ─────────────────────────────────────────────────────────
// 5. APPOINTMENTS
// ─────────────────────────────────────────────────────────

model Appointment {
  id               String            @id @default(uuid())
  patientId        String            @map("patient_id")
  doctorId         String            @map("doctor_id")
  slotId           String            @unique @map("slot_id")
  status           AppointmentStatus @default(PENDING)
  reason           String?
  doctorNotes      String?           @map("doctor_notes")
  rejectionReason  String?           @map("rejection_reason")
  scheduledAt      DateTime          @map("scheduled_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  // Relations
  patient         Patient          @relation(fields: [patientId], references: [id])
  doctor          Doctor           @relation(fields: [doctorId], references: [id])
  slot            AvailabilitySlot @relation(fields: [slotId], references: [id])
  medicalRecords  MedicalRecord[]
  review          Review?

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([scheduledAt])
  @@map("appointments")
}

// ─────────────────────────────────────────────────────────
// 6. MEDICAL RECORDS
// ─────────────────────────────────────────────────────────

model MedicalRecord {
  id                  String    @id @default(uuid())
  patientId           String    @map("patient_id")
  uploadedByDoctorId  String?   @map("uploaded_by_doctor_id")
  appointmentId       String?   @map("appointment_id")
  title               String    @db.VarChar(255)
  description         String?
  fileUrl             String    @map("file_url")
  fileType            String    @map("file_type") @db.VarChar(50)
  fileSizeBytes       Int?      @map("file_size_bytes")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  patient      Patient      @relation(fields: [patientId], references: [id])
  doctor       Doctor?      @relation(fields: [uploadedByDoctorId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([patientId])
  @@index([appointmentId])
  @@map("medical_records")
}

// ─────────────────────────────────────────────────────────
// 7. NOTIFICATIONS
// ─────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  title          String           @db.VarChar(255)
  message        String
  type           NotificationType
  isRead         Boolean          @default(false) @map("is_read")
  referenceId    String?          @map("reference_id")
  referenceType  String?          @map("reference_type") @db.VarChar(50)
  createdAt      DateTime         @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────
// 8. AUDIT LOGS
// ─────────────────────────────────────────────────────────

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String    @db.VarChar(100)
  entity      String    @db.VarChar(100)
  entityId    String    @map("entity_id")
  oldValue    Json?     @map("old_value")
  newValue    Json?     @map("new_value")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user  User?  @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────
// 9. VERIFICATION TOKENS
// ─────────────────────────────────────────────────────────

model VerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId, type])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────
// 10. REVIEWS
// ─────────────────────────────────────────────────────────

model Review {
  id             String    @id @default(uuid())
  patientId      String    @map("patient_id")
  doctorId       String    @map("doctor_id")
  appointmentId  String    @unique @map("appointment_id")
  rating         Int
  comment        String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  patient      Patient     @relation(fields: [patientId], references: [id])
  doctor       Doctor      @relation(fields: [doctorId], references: [id])
  appointment  Appointment @relation(fields: [appointmentId], references: [id])

  @@index([doctorId])
  @@index([patientId])
  @@map("reviews")
}